{
  "name": "pk-rpc",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build:win64": "bun build ./index.ts --compile --target=bun-windows-x64 --outfile ./out/pkrpc_win_x64",
    "build:winarm": "bun build ./index.ts --compile --target=bun-windows-arm64 --outfile ./out/pkrpc_win_arm64",
    "build:linux64": "bun build ./index.ts --compile --target=bun-linux-x64 --outfile ./out/pkrpc_linux_x64",
    "build:linuxarm": "bun build ./index.ts --compile --target=bun-linux-arm64 --outfile ./out/pkrpc_linux_arm64",
    "build:mac64": "bun build ./index.ts --compile --target=bun-darwin-x64 --outfile ./out/pkrpc_darwin_x64",
    "build:macarm": "bun build ./index.ts --compile --target=bun-darwin-arm64 --outfile ./out/pkrpc_darwin_arm64",
    "build:all": "bun run build:win64 && bun run build:winarm && bun run build:linux64 && bun run build:linuxarm && bun run build:mac64 && bun run build:macarm"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "pkapi.js": "^7.4.0"
  }
}
